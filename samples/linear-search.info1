# 線形探索 (Linear Search)
# リストを先頭から順に調べる

def linear_search(a, target):
    count = 0
    for i in range(len(a)):
        count = count + 1
        if a[i] == target:
            print("見つかった: インデックス", i, "（比較回数:", count, "）")
            return i
    print("見つからなかった（比較回数:", count, "）")
    return -1

data = [5, 3, 8, 1, 9, 2, 7, 4, 6]
print("データ:", data)
linear_search(data, 9)
linear_search(data, 10)
